# Convex (generated by `pnpm dev` after logging in)
NEXT_PUBLIC_CONVEX_URL=

# Vercel production builds: Convex deploy key from
# Dashboard → Project Settings → Deploy Keys → Production Deploy Key
# Scope to Production only in Vercel.
# CONVEX_DEPLOY_KEY=

# Vercel preview builds (PRs): separate Preview Deploy Key from the same page.
# Scope to Preview only in Vercel (same variable name, different value).
# CONVEX_DEPLOY_KEY=

# WorkOS AuthKit — from https://dashboard.workos.com
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
# At least 32 characters: openssl rand -base64 24
WORKOS_COOKIE_PASSWORD=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:4271/callback

# MCP API keys — server + Convex (openssl rand -base64 32)
MCP_API_KEY_PEPPER=

# Vercel AI Gateway — https://vercel.com/docs/ai-gateway
# Free tier includes monthly credits; used for AI template generation.
AI_GATEWAY_API_KEY=
# Optional model id (default: openai/gpt-4.1-mini)
# AI_GATEWAY_MODEL=openai/gpt-4.1-mini

# Pro entitlement until billing ships (comma-separated emails).
# Also set on the Convex deployment for the entitlement query.
# PRO_EMAILS=you@example.com

# Allow Settings → "Enable Pro (testing)". Set on Convex deployment.
# ALLOW_MANUAL_PRO=true
