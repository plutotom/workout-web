{
  "name": "workout-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "convex dev --start 'next dev -p 4271'",
    "dev:web": "next dev -p 4271",
    "dev:backend": "convex dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "node scripts/verify.mjs",
    "prepare": "husky"
