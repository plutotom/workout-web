{
  "name": "workout-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "convex dev --start 'next dev -p 4271'",
    "dev:web": "next dev -p 4271",
    "dev:backend": "convex dev",
    "build": "node scripts/vercel-build.mjs",
    "build:web": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "generate:splash": "node scripts/generate-splash-screens.mjs scripts/splash-base.png",
    "verify": "node scripts/verify.mjs",
    "sync:prod": "node scripts/sync-prod.mjs",
    "sync:prod:all": "node scripts/sync-prod.mjs --vercel",
    "sync:preview": "node scripts/sync-preview.mjs",
    "sync:preview:all": "node scripts/sync-preview.mjs --vercel",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/gateway": "^4.0.23",
